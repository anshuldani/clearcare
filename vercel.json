{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "functions": {
    "app/api/analyze-care/route.ts": { "maxDuration": 60 },
    "app/api/analyze-bill/route.ts": { "maxDuration": 60 },
    "app/api/generate-letter/route.ts": { "maxDuration": 30 },
    "app/api/extract-document/route.ts": { "maxDuration": 30 },
    "app/api/insurance-plans/route.ts": { "maxDuration": 15 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        }
      ]
    }
  ]
}

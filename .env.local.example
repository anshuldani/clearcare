# ============================================================
# CLEARCARE — ENVIRONMENT VARIABLES
# ============================================================

# ------------------------------------------------------------
# GEMINI / VERTEX AI  (required)
# ------------------------------------------------------------

# Hackathon key — hits the Vertex AI publisher endpoint:
# https://aiplatform.googleapis.com/v1/publishers/google/models/
# Get from Google Cloud Console > APIs & Services > Credentials
# OR from https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_vertex_ai_key_here

# For standard Vertex AI with Application Default Credentials:
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id
# Then run: gcloud auth application-default login

# ------------------------------------------------------------
# CMS MARKETPLACE API  (optional — enables live insurance data)
# ------------------------------------------------------------
# Free key: https://developer.cms.gov/marketplace-api/key-request.html
# Keys auto-renew every 60 days. Without this, app uses reference data.
# CMS_MARKETPLACE_API_KEY=your_cms_key_here
